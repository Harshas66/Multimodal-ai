# ── Render Backend Environment Variables ──────────────────────

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_EXP_HOURS=168

# Database (Supabase PostgreSQL)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ✅ CORS — Add your Vercel frontend URL here (comma-separated)
ALLOWED_ORIGINS=https://multimodal-ai.vercel.app,https://YOUR-PROJECT.vercel.app

# Firebase Admin (paste full JSON as one line, or use path)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FIREBASE_SERVICE_ACCOUNT_PATH=backend/core/firebase-service-account.json

# LLM Providers
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
HF_TOKEN=hf_...
TAVILY_API_KEY=tvly-...

# HuggingFace Model Config
HF_MODEL_PRIMARY=meta-llama/Llama-3.1-8B-Instruct
HF_MAX_TOKENS=700
HF_TEMPERATURE=0.7
HF_TOP_P=0.9